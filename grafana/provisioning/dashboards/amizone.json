{
  "id": null,
  "uid": "amizone-overview",
  "title": "Amizone Overview",
  "tags": [
    "amizone"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Selected Time Range",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "mode": "markdown",
        "content": "**Viewing:** ${__from:date:YYYY-MM-DD HH:mm:ss} to ${__to:date:YYYY-MM-DD HH:mm:ss}  \nAll summary cards and rate panels follow the active dashboard time range."
      },
      "transparent": true
    },
    {
      "id": 2,
      "title": "Request Rate (req/s, range)",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(amizone_requests_total[$__rate_interval])) or vector(0)",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "description": "Uses Grafana $__rate_interval inside the selected time range."
    },
    {
      "id": 3,
      "title": "Error Rate (err/s, range)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(amizone_errors_total[$__rate_interval])) or vector(0)",
          "legendFormat": "err/s",
          "refId": "A"
        }
      ],
      "description": "Uses Grafana $__rate_interval inside the selected time range."
    },
    {
      "id": 4,
      "title": "Login Attempts (range total)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "sum(increase(amizone_login_attempts_total[$__range])) or vector(0)",
          "legendFormat": "Login Attempts",
          "refId": "A"
        }
      ],
      "description": "Total successful and failed login attempts within the selected time range."
    },
    {
      "id": 5,
      "title": "Cloudflare Challenges (range total)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(amizone_cloudflare_challenges_total[$__range])) or vector(0)",
          "legendFormat": "CF Challenges",
          "refId": "A"
        }
      ],
      "description": "Total Cloudflare challenges observed within the selected time range."
    },
    {
      "id": 6,
      "title": "Peak Goroutines (range)",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "max_over_time(go_goroutines[$__range])",
          "legendFormat": "Goroutines",
          "refId": "A"
        }
      ],
      "description": "Maximum goroutine count seen within the selected time range."
    },
    {
      "id": 14,
      "title": "Unique Users (range)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (user_hash) (increase(amizone_login_attempts_total[$__range])) > 0)",
          "legendFormat": "Unique Users",
          "refId": "A"
        }
      ],
      "description": "Distinct hashed users with at least one login attempt in the selected time range."
    },
    {
      "id": 7,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (method, endpoint_base, status_code) (label_replace(rate(amizone_requests_total[$__rate_interval]), \"endpoint_base\", \"$1\", \"endpoint\", \"([^?]*).*\"))",
          "legendFormat": "{{method}} {{endpoint_base}} {{status_code}}",
          "refId": "A"
        }
      ],
      "description": "Request rate grouped by method, endpoint, and status code using $__rate_interval."
    },
    {
      "id": 8,
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(amizone_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(amizone_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(amizone_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "description": "Latency percentiles computed with $__rate_interval over the selected time range."
    },
    {
      "id": 9,
      "title": "Errors Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(amizone_errors_total[$__rate_interval]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "description": "Error rate grouped by error type using $__rate_interval."
    },
    {
      "id": 10,
      "title": "Login Attempts Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (success) (rate(amizone_login_attempts_total[$__rate_interval]))",
          "legendFormat": "{{success}}",
          "refId": "A"
        }
      ],
      "description": "Login attempt rate grouped by success using $__rate_interval."
    },
    {
      "id": 11,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "Heap In-Use",
          "refId": "B"
        }
      ],
      "description": "Memory series rendered across the selected time range."
    },
    {
      "id": 12,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 22,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[$__rate_interval])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "description": "CPU usage rate over the selected time range using $__rate_interval."
    },
    {
      "id": 13,
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 22,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum[$__rate_interval])",
          "legendFormat": "GC Duration",
          "refId": "A"
        }
      ],
      "description": "Garbage collection duration rate using $__rate_interval."
    }
  ],
  "description": "Operational overview for the Amizone API. Summary cards and rate panels follow the active Grafana time range."
}
